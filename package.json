{
  "name": "devops-test",
  "version": "0.0.0",
  "description": "Basic Hello World app for testing",
  "private": true,
  "main": "src/server.ts",
  "workspaces": [
    "app"
  ],
  "type": "module",
  "scripts": {
    "build": "node app/src/util/build.ts",
    "commitlint": "commitlint --from=$(git rev-parse $(git cherry origin/main | head -n 1 | cut -c 3-)^1)",
    "dev": "nodemon --watch app/src --ext js,ts,scss,html,njk --exec \"npm run start\"",
    "start": "npm run build && node --max-http-header-size=32768 app/src/server.ts",
    "test": "node --test"
  },
  "license": "MIT",
  "dependencies": {
    "body-parser": "^2.3.0",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "govuk-frontend": "^6.4.0",
    "nunjucks": "^3.2.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/nunjucks": "^3.2.6",
    "nodemon": "^3.1.14",
    "sass": "^1.101.0",
    "typescript": "^7.0.2"
  }
}